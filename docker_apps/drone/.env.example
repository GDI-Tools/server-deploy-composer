# Server Configuration
DRONE_SERVER_HOST=drone.yourdomain.com
DRONE_SERVER_PROTO=https
DRONE_HTTP_PORT=8080
DRONE_HTTPS_PORT=8443

# RPC Secret (generate with: openssl rand -hex 16)
DRONE_RPC_SECRET=your_secret_here

# GitHub OAuth Application
DRONE_GITHUB_CLIENT_ID=your_github_client_id
DRONE_GITHUB_CLIENT_SECRET=your_github_client_secret

# Admin Configuration
DRONE_ADMIN_USERNAME=your_github_username

# Optional Settings
DRONE_REGISTRATION_CLOSED=false
DRONE_LOGS_DEBUG=false
DRONE_TLS_AUTOCERT=false

# Runner Configuration
DRONE_RUNNER_CAPACITY=2
DRONE_RUNNER_NAME=main-runner
DRONE_RUNNER_PORT=3000
DRONE_RUNNER_UI_USERNAME=admin
DRONE_RUNNER_UI_PASSWORD=your_runner_password